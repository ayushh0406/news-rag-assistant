__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
MANIFEST

# Virtual Environments
venv/
env/
.venv/
.env/
ENV/
.conda/

# ChromaDB (large binary files — re-generated from URLs)
chroma_db/

